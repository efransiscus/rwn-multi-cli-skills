{
  "name": "project",
  "description": "Project-local agent extending kiro_default with activity-log lifecycle hooks",
  "tools": ["*"],
  "resources": [
    "file://AGENTS.md",
    "file://README.md",
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/*/SKILL.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "\"C:\\Program Files\\Git\\bin\\bash.exe\" .kiro/hooks/activity-log-inject.sh"
      }
    ],
    "stop": [
      {
        "command": "\"C:\\Program Files\\Git\\bin\\bash.exe\" .kiro/hooks/activity-log-remind.sh"
      }
    ]
  },
  "useLegacyMcpJson": true
}
